{
  "rules": [
    {
      "id": "@secretlint/secretlint-rule-pattern",
      "options": {
        "patterns": [
          {
            "name": "OMDB API Key",
            "pattern": "[0-9a-f]{8}",
            "message": "OMDB API Key detected"
          },
          {
            "name": "TMDB API Key",
            "pattern": "[0-9a-f]{32}",
            "message": "TMDB API Key detected"
          },
          {
            "name": "Sentry DSN",
            "pattern": "https://[a-zA-Z0-9]+@[a-zA-Z0-9]+\\.ingest\\.sentry\\.io/[0-9]+",
            "message": "Sentry DSN detected"
          },
          {
            "name": "General API Key",
            "pattern": "api[_-]?key[\"']?\\s*[:=]\\s*[\"']?[a-zA-Z0-9]{16,}[\"']?",
            "message": "Possible API key detected"
          }
        ]
      }
    }
  ]
}
