
{
  "rules": [
    {
      "id": "@secretlint/secretlint-rule-preset-recommend"
    }
  ],
  "ignorePatterns": [
    ".git/",
    "node_modules/",
    "dist/",
    ".env.template"
  ]
}


{
  "scripts": {
    
    "prepare": "husky install",
    "lint:secrets": "secretlint \"**/*\"",
    "precommit": "lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx,astro}": [
      "pnpm lint:secrets"
    ]
  }
}


#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Checking for secrets..."
pnpm lint:secrets

# Check for .env file
if git diff --cached --name-only | grep -q ".env$"; then
  echo "❌ Attempting to commit .env file. Aborting..."
  exit 1
fi

# Additional custom checks for common API keys and tokens
git diff --cached -U0 | grep -i "key[\"':]" && {
  echo "⚠️ Possible API key detected in changes. Please review."
  exit 1
}

git diff --cached -U0 | grep -i "token[\"':]" && {
  echo "⚠️ Possible token detected in changes. Please review."
  exit 1
}

echo "✅ No secrets detected. Proceeding with commit..."
pnpm lint-staged